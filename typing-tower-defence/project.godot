; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="Typing Tower Defence!"
run/main_scene="uid://ws4cm1qoqgge"
config/features=PackedStringArray("4.6", "GL Compatibility")
boot_splash/image="uid://n54m58d228ns"
config/icon="uid://b23vspxb8ehtc"

[autoload]

UiSfxManager="*uid://djhi43b2iy1oq"
GameSelection="*uid://bwa2ushl5h3ue"
WordLists="*uid://dss58n4eqpj4b"
GameSession="*uid://dkr8xqhgtymcr"
PlayerLoadout="*uid://lpu452r3wg4j"

[display]

window/size/viewport_width=960
window/size/viewport_height=540
window/stretch/mode="canvas_items"

[editor_plugins]

enabled=PackedStringArray("res://addons/tile-run-instances/plugin.cfg")

[file_customization]

folder_colors={
"res://Networking/": "pink",
"res://assets/": "purple",
"res://data/": "teal",
"res://scenes/": "yellow",
"res://scripts/": "orange"
}

[physics]

3d/physics_engine="Jolt Physics"

[rendering]

textures/canvas_textures/default_texture_filter=0
rendering_device/driver.windows="d3d12"
renderer/rendering_method="gl_compatibility"
renderer/rendering_method.mobile="gl_compatibility"
2d/snap/snap_2d_transforms_to_pixel=true
