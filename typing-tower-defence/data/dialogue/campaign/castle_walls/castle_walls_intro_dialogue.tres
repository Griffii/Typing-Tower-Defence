[sub_resource type="Resource" id="Line_0"]
script = ExtResource("2_line")
speaker_id = "jisho"
text = "Hurry, {player_name}! The city is under attack!"
add_speakers = Array[String](["player", "jisho"])
move_speakers = {
"jisho": "left_2",
"player": "left_1"
}

[sub_resource type="Resource" id="Line_1"]
script = ExtResource("2_line")
speaker_id = "player"
text = "Uh oh."

[sub_resource type="Resource" id="Line_2"]
script = ExtResource("2_line")
speaker_id = "jisho"
text = "The evil Speller Saborus has sent his minions to steal the Gem of Creation from the castle!"

[sub_resource type="Resource" id="Line_3"]
script = ExtResource("2_line")
speaker_id = "jisho"
text = "We can't let that happen."

[sub_resource type="Resource" id="Line_4"]
script = ExtResource("2_line")
speaker_id = "player"
text = "Ok."

[sub_resource type="Resource" id="Line_5"]
script = ExtResource("2_line")
speaker_id = "jisho"
text = "Stop the soldiers before they break down the castle gates!"

[resource]
script = ExtResource("1_sequence")
