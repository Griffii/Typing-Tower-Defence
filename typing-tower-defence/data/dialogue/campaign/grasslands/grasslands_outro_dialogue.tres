[gd_resource type="Resource" script_class="DialogueSequenceData" format=3 uid="uid://bilub3ljduu5m"]

[ext_resource type="Script" uid="uid://dc1y2b2f7yhje" path="res://data/dialogue/dialogue_sequence_data.gd" id="1_sequence"]
[ext_resource type="Script" uid="uid://bm2xra0mbn2u7" path="res://data/dialogue/dialogue_line_data.gd" id="2_line"]
[ext_resource type="Script" uid="uid://bpi837hrngfsy" path="res://data/dialogue/dialogue_speaker_data.gd" id="3_speaker"]
[ext_resource type="Resource" uid="uid://dgnwns6tacp4j" path="res://data/dialogue/speakers/player_speaker_data.tres" id="4_player"]
[ext_resource type="Resource" uid="uid://cvbt7cg5mp1dq" path="res://data/dialogue/speakers/jisho_speaker_data.tres" id="5_jisho"]

[sub_resource type="Resource" id="Line_0"]
script = ExtResource("2_line")
speaker_id = "jisho"
text = "Take that, you monsters!"
add_speakers = Array[String](["player", "jisho"])
move_speakers = {
"jisho": "left_2",
"player": "left_1"
}

[sub_resource type="Resource" id="Line_3"]
script = ExtResource("2_line")
speaker_id = "jisho"
text = "Those slimes are strong. Saborus's power must be growing."

[sub_resource type="Resource" id="Line_5"]
script = ExtResource("2_line")
speaker_id = "player"
text = "Uh oh."

[sub_resource type="Resource" id="Line_6"]
script = ExtResource("2_line")
speaker_id = "jisho"
text = "Yes. Although..."

[sub_resource type="Resource" id="Line_7"]
script = ExtResource("2_line")
speaker_id = "jisho"
text = "Did you hear the wet pop they make when struck directly with a fireball?"

[sub_resource type="Resource" id="Line_9"]
script = ExtResource("2_line")
speaker_id = "jisho"
text = "Very satisfying."

[sub_resource type="Resource" id="Line_10"]
script = ExtResource("2_line")
speaker_id = "player"
text = "..."

[sub_resource type="Resource" id="Line_12"]
script = ExtResource("2_line")
speaker_id = "jisho"
text = "Still... something about this is strange."

[sub_resource type="Resource" id="Line_13"]
script = ExtResource("2_line")
speaker_id = "jisho"
text = "There was no one inside the church."

[sub_resource type="Resource" id="Line_15"]
script = ExtResource("2_line")
speaker_id = "jisho"
text = "And none of the minions survived long enough to question."

[sub_resource type="Resource" id="Line_16"]
script = ExtResource("2_line")
speaker_id = "jisho"
text = "They may just be rampaging without purpose."

[sub_resource type="Resource" id="Line_17"]
script = ExtResource("2_line")
speaker_id = "jisho"
text = "Perhaps Saborus does not fully control the Gem yet."

[sub_resource type="Resource" id="Line_18"]
script = ExtResource("2_line")
speaker_id = "player"
text = "Good."

[sub_resource type="Resource" id="Line_19"]
script = ExtResource("2_line")
speaker_id = "jisho"
text = "For now, yes."

[sub_resource type="Resource" id="Line_20"]
script = ExtResource("2_line")
speaker_id = "jisho"
text = "But if he learns to master it completely..."

[sub_resource type="Resource" id="Line_21"]
script = ExtResource("2_line")
speaker_id = "jisho"
text = "We should hurry. Let's keep going."

[resource]
script = ExtResource("1_sequence")
speakers = Array[ExtResource("3_speaker")]([ExtResource("4_player"), ExtResource("5_jisho")])
lines = Array[ExtResource("2_line")]([SubResource("Line_0"), SubResource("Line_3"), SubResource("Line_5"), SubResource("Line_6"), SubResource("Line_7"), SubResource("Line_9"), SubResource("Line_10"), SubResource("Line_12"), SubResource("Line_13"), SubResource("Line_15"), SubResource("Line_16"), SubResource("Line_17"), SubResource("Line_18"), SubResource("Line_19"), SubResource("Line_20"), SubResource("Line_21")])
metadata/_custom_type_script = "uid://dc1y2b2f7yhje"
