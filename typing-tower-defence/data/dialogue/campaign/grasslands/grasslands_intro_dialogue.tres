[gd_resource type="Resource" script_class="DialogueSequenceData" format=3 uid="uid://dhvmt4epqox88"]

[ext_resource type="Script" uid="uid://dc1y2b2f7yhje" path="res://data/dialogue/dialogue_sequence_data.gd" id="1_sequence"]
[ext_resource type="Script" uid="uid://bm2xra0mbn2u7" path="res://data/dialogue/dialogue_line_data.gd" id="2_line"]
[ext_resource type="Script" uid="uid://bpi837hrngfsy" path="res://data/dialogue/dialogue_speaker_data.gd" id="3_speaker"]
[ext_resource type="Resource" uid="uid://dgnwns6tacp4j" path="res://data/dialogue/speakers/player_speaker_data.tres" id="4_player"]
[ext_resource type="Resource" uid="uid://cvbt7cg5mp1dq" path="res://data/dialogue/speakers/jisho_speaker_data.tres" id="5_jisho"]

[sub_resource type="Resource" id="Line_0"]
script = ExtResource("2_line")
speaker_id = "jisho"
text = "An old church. It's rather peaceful out here."
add_speakers = Array[String](["player", "jisho"])
move_speakers = {
"jisho": "left_2",
"player": "left_1"
}

[sub_resource type="Resource" id="Line_2"]
script = ExtResource("2_line")
speaker_id = "jisho"
text = "Look!"
move_speakers = {
"jisho": "center_2"
}

[sub_resource type="Resource" id="Line_3"]
script = ExtResource("2_line")
speaker_id = "jisho"
text = "Those are Saborus's minions, and they are coming this way!"

[sub_resource type="Resource" id="Line_5"]
script = ExtResource("2_line")
speaker_id = "jisho"
text = "Why are they attacking this place?"

[sub_resource type="Resource" id="Line_6"]
script = ExtResource("2_line")
speaker_id = "jisho"
text = "We must protect the church, and get some answers from whoever survives."

[sub_resource type="Resource" id="Line_7"]
script = ExtResource("2_line")
speaker_id = "player"
text = "Ok."

[sub_resource type="Resource" id="Line_8"]
script = ExtResource("2_line")
speaker_id = "jisho"
text = "Wait. What are those things with them?"

[sub_resource type="Resource" id="Line_9"]
script = ExtResource("2_line")
speaker_id = "player"
text = "Goo?"

[sub_resource type="Resource" id="Line_10"]
script = ExtResource("2_line")
speaker_id = "jisho"
text = "Slimes."

[sub_resource type="Resource" id="Line_12"]
script = ExtResource("2_line")
speaker_id = "jisho"
text = "Saborus must already be channeling the Gem of Creation to create new minions."

[sub_resource type="Resource" id="Line_14"]
script = ExtResource("2_line")
speaker_id = "player"
text = "Dang."

[sub_resource type="Resource" id="Line_15"]
script = ExtResource("2_line")
speaker_id = "jisho"
text = "Dang indeed. Also very flammable, I hope."

[sub_resource type="Resource" id="Line_16"]
script = ExtResource("2_line")
speaker_id = "jisho"
text = "Get ready, {player_name}. They're coming."

[resource]
script = ExtResource("1_sequence")
speakers = Array[ExtResource("3_speaker")]([ExtResource("4_player"), ExtResource("5_jisho")])
lines = Array[ExtResource("2_line")]([SubResource("Line_0"), SubResource("Line_2"), SubResource("Line_3"), SubResource("Line_5"), SubResource("Line_6"), SubResource("Line_7"), SubResource("Line_8"), SubResource("Line_9"), SubResource("Line_10"), SubResource("Line_12"), SubResource("Line_14"), SubResource("Line_15"), SubResource("Line_16")])
metadata/_custom_type_script = "uid://dc1y2b2f7yhje"
